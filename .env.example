# Copy to `.env` (which is git-ignored) and adjust as needed:  cp .env.example .env
#
# These are LOCAL DEVELOPMENT defaults only — never commit real secrets.
# Production values come from AWS Secrets Manager (ADR-009/010).

# --- PostgreSQL (pgvector) ---
POSTGRES_USER=jobhunter
POSTGRES_PASSWORD=jobhunter_dev_pw
POSTGRES_DB=jobhunter
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Connection URLs (consumed by the API/workers in later PRs) ---
# Host-side URLs (running the app on your machine against the compose stack):
DATABASE_URL=postgresql+psycopg://jobhunter:jobhunter_dev_pw@localhost:5432/jobhunter
REDIS_URL=redis://localhost:6379/0

# --- API (used once the api service lands in PR-004) ---
API_PORT=8000
